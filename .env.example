# =====================================================================
# Plantilla de variables de entorno para conectarse a Oracle.
# Cópialo como `.env` y completa los valores reales.
# IMPORTANTE: el archivo .env NO debe subirse a Git.
# =====================================================================

# --- Credenciales obligatorias ---
ORACLE_USER=ADMIN
ORACLE_PASSWORD=tu_password_segura
ORACLE_DSN=tecniserv_high

# --- Modo de conexión (thick = requiere Oracle Instant Client) ---
ORACLE_THICK_MODE=true

# Ruta al Oracle Instant Client (solo si no está en el PATH del sistema)
# Windows: C:\oracle\instantclient_21_12
# macOS:   /opt/oracle/instantclient_21_12
# Linux:   /opt/oracle/instantclient_21_12
ORACLE_CLIENT_LIB_DIR=

# --- Oracle Cloud Autonomous Database (con wallet) ---
# Carpeta donde descomprimiste el wallet descargado desde la consola
ORACLE_WALLET_DIR=./wallet
ORACLE_WALLET_PASSWORD=
